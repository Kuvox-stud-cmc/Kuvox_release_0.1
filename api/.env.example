# Environment (Development | Production). Production runs without the localhost
# defaults baked into appsettings.Development.json.
ASPNETCORE_ENVIRONMENT=Development

# Cors — default origins live in appsettings.json. To override via env vars use
# indexed keys (the code binds Cors:AllowedOrigins as a string[]):
# Cors__AllowedOrigins__0=https://kuvox.linkednodedigital.com
# Cors__AllowedOrigins__1=http://localhost:5173

# Connection strings for the application
# NOTE: keys must match the code: GetConnectionString("Postgres") / ("Redis").
ConnectionStrings__Postgres=Host=localhost;Port=5432;Database=kuvox;Username=kuvox;Password=kuvox
ConnectionStrings__Redis=localhost:6379

# JWT settings
Jwt__Secret=your_jwt_secret_key
Jwt__Issuer=kuvox_api
Jwt__Audience=kuvox_clients
Jwt__AccessTokenMinutes=15
Jwt__RefreshTokenDays=7

# RabbitMQ settings
RabbitMQ__Host=localhost

# Storage settings
Storage__Endpoint=http://localhost:9000

# AI Services settings
AiService__GrpcUrl=http://localhost:50051

# Email settings (empty ApiKey = dev log mode; set via env in real envs)
Email__ApiKey=
Email__FromEmail=no-reply@kuvox.app
Email__FromName=Kuvox

# Frontend base URL (used for building email verification / password reset links)
Frontend__BaseUrl=http://localhost:5173
